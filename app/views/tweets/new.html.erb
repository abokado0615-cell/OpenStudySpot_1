<div style="font-family: 'Helvetica Neue', Arial, sans-serif; max-width: 600px; margin: 40px auto; padding: 0 20px; box-sizing: border-box;">
  
  <h2 style="font-size: 22px; color: #1d3557; margin: 0 0 5px 0; font-weight: bold; text-align: left;">
    OPEN STUDY SPOT
  </h2>
  <p style="font-size: 14px; color: #7ca4b9; margin: 0 0 25px 0; font-weight: bold; text-align: left;">
    〜 今日の勉強をログに残して共有しよう 〜
  </p>

  <div style="position: relative; background: #fffdf6; border: 2px solid #f3ebd4; border-radius: 12px 12px 0 12px; padding: 30px; box-shadow: -4px 4px 12px rgba(0,0,0,0.02);">
    
    <%= form_for(@tweet) do |f| %>
      
      <% if @tweet.errors.any? %>
        <div style="background: #fef2f2; border: 1px solid #fee2e2; border-radius: 8px; padding: 15px; margin-bottom: 25px;">
          <% @tweet.errors.full_messages.each do |message| %>
            <p style="color: #ef4444; font-size: 13px; margin: 0; font-weight: bold;">⚠️ <%= message %></p>
          <% end %>
        </div>
      <% end %>
      
      <div style="margin-bottom: 25px; text-align: left;">
        <%= f.label :time, "⏰ 勉強時間（任意）", style: "display: block; font-weight: bold; margin-bottom: 10px; font-size: 14px; color: #1d3557;" %>
        <div style="background: #ffffff; padding: 10px 15px; border-radius: 8px; border: 1px solid #e2d9bf;">
          <%= f.time_select :time, { minute_step: 5, include_blank: true } %>
        </div>
      </div>

      <div style="margin-bottom: 25px; text-align: left;">
        <%= f.label :progress, "📝 今回の進捗・やったこと（任意）", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px; color: #1d3557;" %>
        <%= f.text_field :progress, placeholder: "例: 数学のワーク P.10〜15", style: "width: 100%; padding: 12px; border: 1px solid #e2d9bf; border-radius: 8px; box-sizing: border-box; font-size: 14px;" %>
      </div>

      <div style="margin-bottom: 25px; text-align: left;">
        <%= f.label :question, "❓ 疑問点・つまずいたところなど（任意）", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px; color: #1d3557;" %>
        <%= f.text_area :question, rows: 2, placeholder: "みんなに聞きたいことをメモしてみよう", style: "width: 100%; padding: 12px; border: 1px solid #e2d9bf; border-radius: 8px; box-sizing: border-box; font-size: 14px;" %>
      </div>

      <div style="margin-bottom: 25px; text-align: left;">
        <%= f.label :body, "💬 ひとこと・つぶやき（任意）", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px; color: #1d3557;" %>
        <%= f.text_area :body, rows: 3, placeholder: "なんでも自由に共有してみよう！", style: "width: 100%; padding: 12px; border: 1px solid #e2d9bf; border-radius: 8px; box-sizing: border-box; font-size: 14px;" %>
      </div>

      <div style="margin-bottom: 25px; text-align: left;">
        <%= label_tag :tag_list, "🏷️ タグ (カンマ区切りで自由に入力)", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px; color: #1d3557;" %>
        <%= text_field_tag :tag_list, "", placeholder: "例: 数学, 勉強垢, 簿記", style: "width: 100%; padding: 12px; border: 1px solid #e2d9bf; border-radius: 8px; box-sizing: border-box; font-size: 14px;" %>
        
        <div style="font-size: 12px; color: #666; margin-top: 8px;">
          よく使うタグ: 
          <% @suggested_tags&.each do |tag| %>
            <span style="margin-right: 8px; cursor: pointer; color: #7ca4b9; font-weight: bold;" onclick="document.getElementById('tag_list').value += '<%= tag %>, '">
              +<%= tag %>
            </span>
          <% end %>
        </div>
      </div>

      <div style="text-align: center;">
        <%= f.submit "STUDY LOGを共有する ✨", style: "width: 100%; height: 50px; font-size: 15px; background: #1d3557; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 6px rgba(29, 53, 87, 0.2);" %>
      </div>
    <% end %>
  </div>

  <div style="margin-top: 25px; text-align: center;">
    <%= link_to "← みんなのログ一覧に戻る", tweets_path, style: "color: #475569; text-decoration: none; font-weight: bold; font-size: 14px;" %>
  </div>
</div>