<div style="font-family: 'Helvetica Neue', Arial, sans-serif; max-width: 600px; margin: 40px auto; padding: 0 20px; box-sizing: border-box;">
  
  <h2 style="font-size: 22px; color: #1d3557; margin: 0 0 25px 0; padding-bottom: 10px; border-bottom: 2px solid #7ca4b9; font-weight: bold;">
    プロフィールの編集
  </h2>
<%= form_for(@user, url: user_path(@user), html: { method: :put, multipart: true }) do |f| %>
   <%= form_for(resource, as: resource_name, url: registration_path(resource_name), method: :put) do |f| %>
      <div style="text-align: center; margin-bottom: 30px; border-bottom: 1px solid #f0f0f0; padding-bottom: 20px;">
        <div style="margin-bottom: 15px;">
          <% if @user.image.attached? %>
            <%= image_tag @user.image, style: "width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid #7ca4b9;" %>
          <% else %>
            <div style="width: 120px; height: 120px; border-radius: 50%; background: #e5e9ec; color: #7ca4b9; display: flex; align-items: center; justify-content: center; font-size: 50px; margin: 0 auto; border: 3px solid #7ca4b9;">👤</div>
          <% end %>
        </div>
        <%= f.label :image, "プロフィール画像を変更", style: "display: inline-block; background: #f0f4f8; color: #1d3557; padding: 8px 16px; border-radius: 20px; font-size: 13px; font-weight: bold; cursor: pointer;" %>
        <%= f.file_field :image, style: "display: none;" %>
      </div>

      <div style="margin-bottom: 20px;">
        <%= f.label :name, "名前", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px;" %>
        <%= f.text_field :name, autofocus: true, style: "width: 100%; padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc;" %>
      </div>

      <div style="margin-bottom: 20px;">
        <%= f.label :email, "メールアドレス", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px;" %>
        <%= f.email_field :email, style: "width: 100%; padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc;" %>
      </div>

      <div style="margin-bottom: 20px;">
        <%= f.label :occupation, "学年・職業", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px;" %>
        <%= f.select :occupation, [["中学", "中学"], ["高校", "高校"], ["大学", "大学"], ["大学院", "大学院"], ["専門", "専門"], ["社会人", "社会人"], ["その他", "その他"]], { include_blank: "選択してください" }, style: "width: 100%; padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc;" %>
      </div>

      <div style="margin-bottom: 20px;">
        <%= f.label :study_tags, "普段やってる勉強（カンマ区切りで入力）", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px;" %>
        <%= f.text_field :study_tags, class: "tag-input-field", placeholder: "例: Rails, 英語, 数学", style: "width: 100%; padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc;" %>
        <span style="font-size: 12px; color: #777; display: block; margin-top: 4px;">※後ほどタグ機能として実装予定です。</span>
      </div>

      <div style="margin-bottom: 25px;">
        <%= f.label :profile, "自己紹介", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px;" %>
        <%= f.text_area :profile, rows: 4, style: "width: 100%; padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 6px; background: #f8fafc; resize: vertical;" %>
      </div>

      <div style="margin-bottom: 30px; border-top: 1px dashed #e2e8f0; padding-top: 20px;">
        <h3 style="font-size: 16px; color: #1d3557; margin: 0 0 15px 0; font-weight: bold;">SNS連携</h3>
        
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
          <div style="width: 32px; height: 32px; background: linear-gradient(45deg, #FFDC80, #FD1D1D, #833AB4); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">I</div>
          <div style="flex: 1;">
            <%= f.text_field :instagram_id, placeholder: "Instagram ID (例: study_spot)", style: "width: 100%; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px;" %>
          </div>
        </div>

        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
          <div style="width: 32px; height: 32px; background: #000000; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">X</div>
          <div style="flex: 1;">
            <%= f.text_field :x_id, placeholder: "X ID (例: study_spot_jp)", style: "width: 100%; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px;" %>
          </div>
        </div>

        <div style="display: flex; align-items: center; gap: 10px;">
          <div style="width: 32px; height: 32px; background: #010101; border-radius: 8px; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; border-right: 2px solid #ff0050; border-left: 2px solid #00f2ea;">T</div>
          <div style="flex: 1;">
            <%= f.text_field :tiktok_id, placeholder: "TikTok ID (例: study_spot_vlog)", style: "width: 100%; padding: 8px 12px; border: 1px solid #cbd5e1; border-radius: 6px;" %>
          </div>
        </div>
      </div>

      <div style="text-align: center;">
        <%= f.submit "変更を保存する", style: "width: 100%; height: 48px; font-size: 15px; background: #1d3557; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer;" %>
      </div>
    <% end %>
  </div>

  <div style="margin-top: 25px; display: flex; justify-content: center; gap: 15px;">
    <%= link_to "マイページに戻る", user_path(current_user.id), style: "background: #7ca4b9; color: white; text-decoration: none; padding: 12px; border-radius: 8px; font-weight: bold; flex: 1; font-size: 14px; text-align: center;" %>
    <%= link_to "投稿一覧に戻る", tweets_path, style: "background: #475569; color: white; text-decoration: none; padding: 12px; border-radius: 8px; font-weight: bold; flex: 1; font-size: 14px; text-align: center;" %>
  </div>

</div>