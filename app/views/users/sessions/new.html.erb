<div style="font-family: 'Helvetica Neue', Arial, sans-serif; max-width: 450px; margin: 60px auto; padding: 0 20px; box-sizing: border-box;">
  
  <h2 style="font-size: 22px; color: #1d3557; margin: 0 0 5px 0; font-weight: bold; text-align: center;">
    Welcome Back!
  </h2>
  <p style="font-size: 13px; color: #7ca4b9; margin: 0 0 25px 0; font-weight: bold; text-align: center;">
    〜 ログインして勉強ログを再開しよう 〜
  </p>

  <div style="position: relative; background: #fffdf6; border: 2px solid #f3ebd4; border-radius: 12px; padding: 35px 30px; box-shadow: -4px 4px 12px rgba(0,0,0,0.03); box-sizing: border-box; overflow: hidden;">
    
    <div style="position: absolute; bottom: 0; right: 0; width: 0; height: 0; border-style: solid; border-width: 0 0 20px 20px; border-color: transparent transparent #ffffff #ded3b7; box-shadow: -2px -2px 4px rgba(0,0,0,0.06);"></div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      
      <div style="margin-bottom: 20px; text-align: left;">
        <%= f.label :email, "✉️ メールアドレス", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px; color: #1d3557;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "example@email.com", style: "width: 100%; padding: 12px; border: 1px solid #e2d9bf; border-radius: 8px; box-sizing: border-box; font-size: 14px; background: #ffffff;" %>
      </div>

      <div style="margin-bottom: 20px; text-align: left;">
        <%= f.label :password, "🔒 パスワード", style: "display: block; font-weight: bold; margin-bottom: 8px; font-size: 14px; color: #1d3557;" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", style: "width: 100%; padding: 12px; border: 1px solid #e2d9bf; border-radius: 8px; box-sizing: border-box; font-size: 14px; background: #ffffff;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div style="margin-bottom: 25px; text-align: left; display: flex; align-items: center; gap: 8px; cursor: pointer;">
          <%= f.check_box :remember_me, style: "width: 16px; height: 16px; cursor: pointer; accent-color: #1d3557;" %>
          <%= f.label :remember_me, "ログイン状態を保持する", style: "font-size: 13px; color: #475569; user-select: none; cursor: pointer;" %>
        </div>
      <% end %>

      <div style="text-align: center; margin-bottom: 15px;">
        <%= f.submit "ログインする", style: "width: 100%; height: 48px; font-size: 15px; background: #1d3557; color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; box-shadow: 0 4px 6px rgba(29, 53, 87, 0.2);" %>
      </div>

    <% end %>
  </div>

  <div style="margin-top: 25px; text-align: center; display: flex; flex-direction: column; gap: 10px;">
    <%= link_to "➔ 初めての方はこちら（新規登録）", new_registration_path(resource_name), style: "color: #7ca4b9; text-decoration: none; font-weight: bold; font-size: 13px;" %>
    <%= link_to "パスワードを忘れた場合", new_password_path(resource_name), style: "color: #94a3b8; text-decoration: none; font-size: 12px;" %>
  </div>

</div>