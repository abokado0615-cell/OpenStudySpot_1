<!DOCTYPE html>
<html>
  <head>
    <title>OpenStudySpot</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>

    <div style="margin-top: 5px; display: flex; gap: 8px;">
     <% @suggested_tags.each do |tag| %>
       <%= link_to tag, tweets_path(tag: tag), style: "color: #e0f2fe; font-size: 12px; text-decoration: underline;" %>
     <% end %>
    </div>
  </head>

  <body>
    <header style="background: #7ca4b9; padding: 15px 20px; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); box-sizing: border-box; width: 100%;">
      
      <h1 style="margin: 0; font-size: 20px; color: #1d3557; font-weight: bold;">
        <%= link_to "OPEN STUDY SPOT", root_path, style: "text-decoration: none; color: white;" %>
      </h1>
      
      <%= form_tag(tweets_path, method: :get, style: "display: flex; gap: 5px;") do %>
        <%= text_field_tag :tag, params[:tag], placeholder: "タグ検索...", style: "padding: 6px 12px; border-radius: 20px; border: none; font-size: 14px; width: 180px;" %>
        <%= submit_tag '検索', style: "background: #1d3557; color: white; border: none; padding: 6px 15px; border-radius: 20px; cursor: pointer; font-size: 14px;" %>
      <% end %>

      <div style="display: flex; align-items: center; gap: 15px;">
        <% if user_signed_in? %>
          <%= link_to "ログアウト", destroy_user_session_path, method: :delete, style: "color: white; font-size: 14px; text-decoration: none;" %>
          <%= link_to user_path(current_user.id), style: "text-decoration: none;" do %>
            <% if current_user.respond_to?(:image) && current_user.image.attached? %>
              <%= image_tag current_user.image, style: "width: 40px; height: 40px; border-radius: 50%; object-fit: cover; border: 2px solid white;" %>
            <% else %>
              <div style="width: 40px; height: 40px; border-radius: 50%; background: white; color: #7ca4b9; display: flex; align-items: center; justify-content: center; font-size: 20px; border: 2px solid white;">👤</div>
            <% end %>
          <% end %>
        <% else %>
          <%= link_to "ログイン", new_user_session_path, style: "color: white; text-decoration: none; font-size: 14px;" %>
          <%= link_to "新規登録", new_user_registration_path, style: "background: #1d3557; color: white; padding: 6px 12px; border-radius: 6px; text-decoration: none; font-size: 14px;" %>
        <% end %>
      </div>
    </header>

    <%= yield %>
  </body>
</html>